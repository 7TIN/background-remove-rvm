{
  "name": "background-remove",
  "module": "src/server.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "setup:python-first": "uv venv && uv pip install -r requirements.txt && mkdir -p storage",
    "setup:python": "uv pip install -r requirements.txt",
    "setup:rvm": "python -c \"import sys; sys.path.insert(0, '.'); from rvm_matting import setup; setup()\"",
    "dev": "bun run --watch server.ts",
    "start": "bun run server.ts",
    "start:prod": "NODE_ENV=production bun run server.ts"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "hono": "^4.12.26"
  }
}
